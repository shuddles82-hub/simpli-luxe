# Airtable read-only access. Real values go in .env.local (never committed)
# and in Vercel project settings (Settings > Environment Variables).
#
# AIRTABLE_TOKEN: create at airtable.com/create/tokens
#   - Scope: data.records:read ONLY
#   - Access: ONLY the Simpli Luxe base
# AIRTABLE_BASE_ID: open the base, copy the part of the URL starting with "app"
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=

# Supabase (member accounts + saves). From your Supabase project:
# Settings > API. The URL and the "anon public" key. These two are
# safe for the browser; row-level security protects all member data.
# Never put the service_role key here or anywhere in this project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SimpliBot (Phase 5). Create a key at console.anthropic.com under
# API Keys. Server-side only; never shipped to the browser.
ANTHROPIC_API_KEY=

# Stripe (Luxe Insider subscription). All server-side only.
# From dashboard.stripe.com > Developers > API keys (Secret key).
STRIPE_SECRET_KEY=
# The recurring price you create for Luxe Insider (starts with "price_").
STRIPE_PRICE_ID=
# From the webhook endpoint you add in Stripe (starts with "whsec_").
STRIPE_WEBHOOK_SECRET=
# Supabase service-role key: Settings > API > service_role. SERVER ONLY.
# This is powerful. Never prefix it with NEXT_PUBLIC and never share it.
SUPABASE_SERVICE_ROLE_KEY=
